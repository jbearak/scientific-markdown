{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "sight/src/dta-parser/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "src/test",
    "**/*.test.ts",
    "test",
    "scripts",
    "sight"
  ]
}
