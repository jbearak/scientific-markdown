# Source files (keep compiled output)
src/**

# Local/test artifacts
.vscode-test/**
test/**
tests/**
out/**/*.test.js
out/test-*.js
out/__mocks__/**
.*.bun-build
dist/**

# Git and editor metadata
.git/**
.gitignore
.kiro/**
.claude/**
.vscode/**
.github/**
.editorconfig
.eslintrc*
tsconfig.json
jsconfig.json
tslint.json
out/**/*.map

# Docs not needed in package
AGENTS.md
ARCHITECTURE.md
IMPLEMENTATION_SUMMARY.md
MANUAL_TEST_*.md
TABLE_REFLOW_IMPLEMENTATION.md
CLAUDE.md
docs/**

# Misc repo files not needed in extension package
*.vsix
*.docx
sample.png
example.qmd
bun.lock
esbuild.mjs
setup.sh
scripts/**
revised_temp/**
full_draft_temp/**
*_temp/**
.tmp/**

# Native binaries (built separately, not needed in extension package)
bin/**

# Dependencies are bundled by esbuild into out/; exclude raw node_modules
node_modules/**
